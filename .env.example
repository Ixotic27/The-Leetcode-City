# LeetCode City - Environment Variables Template
# Copy this file to .env.local and fill in your own values.

# Supabase (Required for Database & Auth)
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# GitHub (Required for API interactions and Auth)
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=your-github-token

# Stripe (Optional - for Point Shop payments)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App URL (For Auth callbacks)
NEXT_PUBLIC_SITE_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Google Generative AI (Optional - for advanced features)
GOOGLE_GENAI_API_KEY=your-api-key

# NowPayments (Optional - for crypto payments)
NOWPAYMENTS_API_KEY=your-api-key
NOWPAYMENTS_IPN_SECRET=your-ipn-secret
